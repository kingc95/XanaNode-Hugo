{
  "id": "xananode.example",
  "name": "XanaNode Hugo Substrate",
  "description": "A Hugo-published XanaNode-compatible knowledge substrate.",
  "version": "0.1.0",
  "namespace": "xananode.example",
  "repository": {
    "type": "git",
    "url": "https://github.com/kingc95/xananode-hugo",
    "default_branch": "main"
  },
  "schema_version": "xananode-core@0.5.1",
  "imports": [
    "xananode:core",
    {
      "mode": "mounted",
      "id": "xananode.canonical",
      "source": "../../XanaNode-Canonical-Substrate",
      "version": "0.1.0",
      "required": true
    },
    {
      "mode": "mounted",
      "id": "imports:lineage",
      "source": "imports/lineage"
    },
    {
      "mode": "mounted",
      "id": "imports:review-fixture",
      "source": "imports/review-fixture"
    }
  ]
}
