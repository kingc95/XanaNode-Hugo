{
  "id": "xananode.example",
  "name": "XanaNode Hugo Substrate",
  "description": "A Hugo-published XanaNode-compatible knowledge substrate.",
  "version": "0.1.0",
  "namespace": "xananode.example",
  "repository": {
    "type": "git",
    "url": "https://github.com/kingc95/xananode-hugo",
    "default_branch": "main"
  },
  "schema_version": "xananode-core@0.5.0",
  "imports": [
    "xananode:core",
    {
      "mode": "mounted",
      "id": "example.minimal",
      "source": "../vendor/xananode-core/vendor/xananode-protocol/examples/minimal-substrate",
      "version": "0.2.0",
      "required": true
    },
    {
      "mode": "mounted",
      "id": "xananode.canonical",
      "source": "packs/xananode-canonical",
      "version": "0.1.0",
      "required": false
    },
    {
      "mode": "mounted",
      "id": "imports:lineage",
      "source": "imports/lineage"
    }
  ]
}
