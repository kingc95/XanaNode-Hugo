  "content": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"$id\": \"https://xananode.org/schemas/substrate-relationships.schema.json\",\r\n  \"title\": \"Substrate Relationship List\",\r\n  \"type\": \"object\",\r\n  \"additionalProperties\": false,\r\n  \"required\": [\"relationships\"],\r\n  \"properties\": {\r\n    \"relationships\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"required\": [\"id\", \"source\", \"target\", \"type\", \"summary\"],\r\n        \"properties\": {\r\n          \"id\": { \"type\": \"string\" },\r\n          \"source\": { \"type\": \"string\" },\r\n          \"target\": { \"type\": \"string\" },\r\n          \"type\": {\r\n            \"type\": \"string\",\r\n            \"pattern\": \"^([a-z][a-z0-9_-]*(\\\\.[a-z][a-z0-9_-]*)*:)?[a-z][a-z0-9_-]*$\"\r\n          },\r\n          \"weight\": {\r\n            \"type\": \"integer\",\r\n            \"minimum\": 1,\r\n            \"maximum\": 5\r\n          },\r\n          \"visibility\": {\r\n            \"type\": \"string\",\r\n            \"enum\": [\"primary\", \"secondary\", \"background\"]\r\n          },\r\n          \"summary\": { \"type\": \"string\" },\n          \"asserted_by\": { \"type\": \"string\" },\n          \"asserted_at\": { \"type\": \"string\", \"format\": \"date-time\" },\n          \"valid_from\": { \"type\": \"string\", \"format\": \"date-time\" },\n          \"valid_to\": { \"type\": \"string\", \"format\": \"date-time\" },\n          \"confidence\": { \"type\": \"string\" },\n          \"content_id\": { \"type\": \"string\" },\n          \"version_id\": { \"type\": \"string\" },\n          \"signature\": { \"type\": \"string\" },\n          \"tumbler\": {\n            \"type\": \"string\",\n            \"pattern\": \"^[a-z][a-z0-9_-]*(\\\\.[a-z][a-z0-9_-]*)*:[a-z][a-z0-9_-]*/[^\\\\s#@]+(@[^\\\\s#]+)?(#fragment/[A-Za-z0-9._-]+(@[^\\\\s#]+)?)?$\"\n          },\n          \"evidence\": {\r\n            \"type\": \"array\",\r\n            \"items\": { \"type\": \"string\" }\r\n          },\r\n          \"external\": { \"type\": \"boolean\" },\r\n          \"target_substrate\": { \"type\": \"string\" }\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n",
