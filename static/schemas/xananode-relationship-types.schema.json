{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://builtbybots.com/schemas/xananode-relationship-types.schema.json",
  "title": "XanaNode Allowed Relationship Types",
  "description": "Canonical relationship type registry for XanaNode.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "relationship_types"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "relationship_types": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "label",
          "category",
          "meaning",
          "default_weight",
          "default_visibility"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "causation",
              "citation",
              "claim_structure",
              "comparison",
              "composition",
              "creation",
              "definition",
              "evidence",
              "explanation",
              "generic",
              "governance",
              "historical",
              "influence",
              "lineage",
              "location",
              "participation",
              "reasoning",
              "representation",
              "revision",
              "social",
              "temporal"
            ]
          },
          "meaning": {
            "type": "string"
          },
          "inverse": {
            "type": "string"
          },
          "default_weight": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "default_visibility": {
            "type": "string",
            "enum": [
              "primary",
              "secondary",
              "background"
            ]
          }
        }
      }
    }
  }
}
