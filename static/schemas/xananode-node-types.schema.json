{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://builtbybots.com/schemas/xananode-node-types.schema.json",
  "title": "XanaNode Allowed Node Types",
  "description": "Canonical node type registry for XanaNode.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "node_types"],
  "properties": {
    "version": {
      "type": "string"
    },
    "node_types": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "label", "purpose", "allowed_subtypes", "color"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "person",
              "concept",
              "claim",
              "source",
              "essay",
              "observation",
              "media",
              "event",
              "place",
              "organization",
              "project",
              "technology",
              "publication",
              "community",
              "relationship",
              "revision",
              "trail",
              "schema"
            ]
          },
          "label": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "allowed_subtypes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_frontmatter": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_frontmatter": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "color": {
            "type": "object",
            "additionalProperties": false,
            "required": ["bg", "fg", "outline"],
            "properties": {
              "bg": {
                "type": "string"
              },
              "fg": {
                "type": "string"
              },
              "outline": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
