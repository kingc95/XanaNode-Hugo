  "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n  {{ partial \"head.html\" . }}\r\n  <title>Resolve XanaNode Reference | {{ site.Title }}</title>\r\n</head>\r\n<body>\r\n  <main class=\"site-main\">\r\n    <section class=\"xana-app xana-404-shell\" data-xana-404-resolver=\"true\">\r\n      <div id=\"xana-graph\"></div>\r\n\r\n      <aside id=\"xana-panel\" class=\"xana-panel xana-404-panel\">\r\n        <div class=\"xana-document-view xana-404-view\">\r\n          <p class=\"xana-inline-type\">404</p>\r\n          <h1>That route is not published</h1>\r\n          <p class=\"xana-404-lead\">\r\n            XanaNode publishes typed pages, not a generic <code>/nodes/</code> bucket.\r\n            Use the node's type route instead.\r\n          </p>\r\n\r\n          <div class=\"xana-404-callout\">\r\n            <p class=\"xana-404-label\">Try this route</p>\r\n            <a class=\"xana-404-link\" href=\"{{ \"/trail/start-here/\" | relURL }}\">/trail/start-here/</a>\r\n            <p class=\"xana-404-note\">\r\n              Start Here is a trail node, so its public page lives under <code>/trail/</code>.\r\n            </p>\r\n          </div>\r\n\r\n          <p class=\"xana-404-note\">\r\n            If you were trying to reach a different node, open the home view and follow the type-specific links from there.\r\n          </p>\r\n\r\n          <p>\r\n            <a class=\"xana-404-home\" href=\"{{ \"/\" | relURL }}\">Return to home</a>\r\n          </p>\r\n\r\n          <noscript>\r\n            <p class=\"xana-empty\">This path did not match a generated page. Enable JavaScript to resolve XanaNode protocol and fragment addresses.</p>\r\n          </noscript>\r\n        </div>\r\n      </aside>\r\n    </section>\r\n\r\n    <script type=\"module\" src=\"{{ \"js/xananode.js\" | relURL }}?v={{ now.UnixNano }}\"></script>\r\n  </main>\r\n</body>\r\n</html>\r\n",
