    "example:build": "npm run prepare && hugo --source exampleSite --themesDir ../.. --gc --minify"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "gray-matter": "^4.0.3",
    "glob": "^11.0.0"
  }
}
